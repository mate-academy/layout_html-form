ation</legend>\n        <label for=\"registrationEmail\">\n          Email :\n          <input type=\"email\" placeholder=\"email@example.com\" name=\"email\" id=\"registrationEmail\">\n        </label>\n        <label for=\"registrationPass\">\n          Password :\n          <input type=\"password\" minlength=\"5\" maxlength=\"32\" placeholder=\"6 didits\" pattern=\"\\d+\" name=\"password\" id=\"registrationPass\">\n        </label>\n      </fieldset>\n      <fieldset>\n        <legend>An interesting fact about you!</legend>\n        <label for=\"factCats\">\n          Do you love cats?\n          <input type=\"radio\" value=\"yes\" name=\"loveCats\" id=\"factCats\"> Yes\n          <input type=\"radio\" value=\"no\" name=\"loveCats\" id=\"factCats\"> No\n        </label>\n        <label for=\"factColor\">\n          What is your favorite color ?\n          <input type=\"color\" name=\"favColor\" id=\"factColor\">\n        </label>\n        <label for=\"factBedTime\">\n          What time do you go to bed?\n          <input type=\"time\" name=\"bedTime\" id=\"factBedTime\">\n        </label>\n        <label for=\"factCarBrand\">\n          What are your favorite brand of cars?\n          <select name=\"carBrands\" id=\"factCarBrand\" multiple=\"\">\n            <option value=\"bmw\">BMW</option>\n            <option value=\"audi\">Audi</option>\n            <option value=\"mercedes\">Mercedes-Benz</option>\n          </select>\n        </label>\n        <label for=\"factLike\">\n          How do you rate our work ?\n          <input type=\"range\" required=\"\" name=\"likeOfWork\" min=\"10\" max=\"100\" step=\"1\" id=\"factLike\"></label>\n      </fieldset>\n      <fieldset>\n        <legend>Additional Info</legend>\n        <label for=\"additionalComments\">\n          Comments :\n          <textarea name=\"comment\" id=\"additionalComments\" cols=\"25\" rows=\"5\"></textarea>\n        </label>\n        <label for=\"additionalRecommend\">\n          Would you recommend us ?\n          <select name=\"reccomend\" id=\"additionalRecommend\">\n            <option value=\"\" selected=\"\" disabled=\"\">choose : </option>\n            <option value=\"yes\">yes</option>\n            <option value=\"no\">no</option>\n            <option value=\"notSure\">not sure yet</option>\n          </select>\n        </label>\n      </fieldset>\n      <button>submit</button>\n    </form>\n    <script type=\"text/javascript\" src=\"/7a9076d6d94e62c13d641aa71f19ae8e.js\"></script>\n  </body>\n</html>\n"},"sourceMaps":null,"error":null,"hash":"e7457099d23d013957f7c26bc175cb16","cacheData":{}}